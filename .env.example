# Copy this file to `.env` and fill in your real values.
# Get these from https://www.linkedin.com/developers/apps -> your app -> Auth tab.

LINKEDIN_CLIENT_ID=86wzpti873r7ps
LINKEDIN_CLIENT_SECRET=your-new-client-secret-here

# Must match an entry in the app's "Authorized redirect URLs" exactly.
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback

# Scopes. w_member_social = post on your behalf; openid/profile/email = identity.
LINKEDIN_SCOPES=openid profile email w_member_social

# LinkedIn versioned API month (YYYYMM) for the Posts API. Bump occasionally.
LINKEDIN_API_VERSION=202405

# --- LLM (for generate / polish / optimize / repurpose / A/B / triage) ---
# Pick one provider and set its key. Model defaults are sensible but overridable.
LLM_PROVIDER=anthropic            # anthropic | openai | gemini
# Defaults: anthropic=claude-sonnet-4-6, openai=gpt-5.1, gemini=gemini-2.5-pro
# LLM_MODEL=claude-opus-4-8       # override the per-provider default
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1024
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Optional: confine uploaded media to this directory (defense-in-depth).
# LINKEDIN_MEDIA_DIR=/Users/you/linkedin-media
